# Copy thành .env và điền giá trị. File .env không được commit.
# Database (PostgreSQL)
# Railway: reference từ service Postgres → PGHOST→DB_HOST, PGPORT→DB_PORT, PGDATABASE→DB_NAME, PGUSER→DB_USER, PGPASSWORD→DB_PASSWORD
# Local dùng DB Railway: lấy DATABASE_PUBLIC_URL (host public, không dùng postgres.railway.internal) rồi tách ra điền bên dưới.
DB_HOST=localhost
DB_PORT=5433
DB_NAME=flourishtravel
DB_USER=postgres
DB_PASSWORD=admin123a
# Local Postgres: DB_SSL_MODE mặc định disable (application.yml). DigitalOcean / cloud TLS:
# DB_SSL_MODE=require

# --- DigitalOcean Managed PostgreSQL (cloud DB) ---
# Dashboard → Databases → flourishtourism → Connection details (Public network nếu chạy local/ECS).
# DB_HOST=db-postgresql-sgp1-flourishtourism-do-user-37760190-0.m.db.ondigitalocean.com
# DB_PORT=25060
# DB_NAME=defaultdb
# DB_USER=doadmin
# DB_PASSWORD=<password từ DO dashboard>
# DB_SSL_MODE=require
#
# Quan trọng: profile `dev` (application-dev.yml) dùng H2 in-memory, KHÔNG ghi cloud DB.
# Chạy BE trỏ DO: KHÔNG bật profile dev — load BE/.env rồi `mvn spring-boot:run`.
# ECS / Docker: SPRING_PROFILES_ACTIVE=cloud — mặc định DO trong application-cloud.yml; bắt buộc DB_PASSWORD.

# JWT (đổi secret khi deploy)
JWT_SECRET=your-256-bit-secret-key-at-least-32-chars

# Chatbot LLM — OpenRouter (Google Gemini 3 Flash Preview)
OPENROUTER_API_KEY=
# OPENROUTER_MODEL=google/gemini-3-flash-preview
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Chatbot thời tiết + địa điểm gần: dùng Open-Meteo & Overpass (OSM), không cần API key

# Server & Frontend
SERVER_PORT=8080
FRONTEND_URL=http://localhost:5173

# Upload: local (mặc định) hoặc s3
# UPLOAD_STORAGE=s3
# S3_BUCKET=ten-bucket
# S3_REGION=ap-southeast-1
# AWS_REGION=ap-southeast-1
# Khuyến nghị cho S3 upload (tránh Windows/IDE đã set sẵn AWS_ACCESS_KEY_ID sai → .env bị bỏ qua):
# S3_UPLOAD_ACCESS_KEY_ID=AKIA...
# S3_UPLOAD_SECRET_ACCESS_KEY=...
# Hoặc dùng AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY (BE map sang aws.accessKeyId cho default SDK).
# Tuỳ chọn CloudFront / domain: S3_PUBLIC_URL_PREFIX=https://dxxxx.cloudfront.net

# MoMo, PII_ENCRYPTION_KEY, GOOGLE_MAPS_API_KEY... (xem application.yml)
