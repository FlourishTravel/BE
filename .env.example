# Copy thành .env và điền giá trị. File .env không được commit.
# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5433
DB_NAME=flourishtravel
DB_USER=postgres
DB_PASSWORD=

# JWT (đổi secret khi deploy)
JWT_SECRET=your-256-bit-secret-key-at-least-32-chars

# Chatbot – chỉ cần 1 trong 2
GEMINI_API_KEY=
OPENAI_API_KEY=

# Server & Frontend
SERVER_PORT=8080
FRONTEND_URL=http://localhost:5173

# MoMo, PII_ENCRYPTION_KEY, GOOGLE_MAPS_API_KEY... (xem application.yml)
